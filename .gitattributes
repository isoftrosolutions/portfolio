# Normalize line endings: let Git handle text automatically
* text=auto

# Explicit text files (LF in repo)
*.html  text
*.css   text
*.js    text
*.json  text
*.xml   text
*.svg   text
*.md    text
*.txt   text

# Binary files (never normalize or diff)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
